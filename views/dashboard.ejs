<link rel="stylesheet" href="/dashboard.css">
<body>

<header>
  <h1>Admin Panel (CRUD)</h1>
  <form action="/logout" method="post">
    <button type="submit" class="delete">Logout</button>
  </form>
</header>

<div class="container">

  <!-- SEARCH -->
  <form method="GET" action="/dashboard">
    <input
      type="text"
      name="search"
      placeholder="Search by name or email"
      value="<%= search || '' %>"
    />
    <button type="submit">Search</button>
  </form>

  <hr>

  <!-- CREATE USER -->
  <form action="/admin/create" method="POST">
    <input type="text" name="name" placeholder="Name" required />
    <input type="email" name="email" placeholder="Email" required />
    <input type="password" name="password" placeholder="Password" required />
    <button type="submit" class="create">Create User</button>
  </form>

  <hr>

  <!-- USER TABLE -->
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th colspan="2">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (users.length === 0) { %>
        <tr>
          <td colspan="4">No users found</td>
        </tr>
      <% } %>

      <% users.forEach(user => { %>
        <tr>

          <!-- UPDATE USER -->
          <form action="/admin/update/<%= user._id %>" method="POST">
            <td>
              <input type="text" name="name" value="<%= user.name %>" required>
            </td>
            <td>
              <input type="email" name="email" value="<%= user.email %>" required>
            </td>
            <td>
              <button type="submit" class="update">Update</button>
            </td>
          </form>

          <!-- DELETE USER -->
          <td>
            <form action="/admin/delete/<%= user._id %>" method="POST">
              <button
                type="submit"
                class="delete"
                onclick="return confirm('Are you sure you want to delete this user?')">
                Delete
              </button>
            </form>
          </td>

        </tr>
      <% }) %>
    </tbody>
  </table>

</div>

</body>